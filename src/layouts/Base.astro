---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, description = "A modern French grammar reference.", breadcrumb = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · Frenchlation</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="brand">Frenchlation</a>
      {breadcrumb.length > 0 && (
        <ol class="breadcrumb">
          {breadcrumb.map(({ label, href }) => (
            <li>{href ? <a href={href}>{label}</a> : label}</li>
          ))}
        </ol>
      )}
    </nav>

    <main class="container">
      <slot />
    </main>
  </body>
</html>
