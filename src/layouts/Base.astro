---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  breadcrumb?: { label: string; href?: string }[];
}

const { title, description = "An interactive French grammar reference.", breadcrumb = [] } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} · La Coquille</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="brand">La Coquille</a>
      {breadcrumb.length > 0 && (
        <>
          <span class="sep">·</span>
          <ol class="breadcrumb">
            {breadcrumb.map(({ label, href }) => (
              <li>{href ? <a href={href}>{label}</a> : label}</li>
            ))}
          </ol>
        </>
      )}
    </nav>

    <main>
      <slot />
    </main>
  </body>
</html>
