---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";

export async function getStaticPaths() {
  const entries = await getCollection("grammar");
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, oneLineRule } = entry.data;

// Build breadcrumb from slug (e.g., "pronouns/subject-pronouns" → pronouns → subject pronouns)
const slugParts = entry.id.split("/");
const breadcrumb = slugParts.map((part: string, i: number) => ({
  label: part === "index" ? slugParts[i - 1] || "Grammar" : part.replace(/-/g, " "),
  href: i < slugParts.length - 1 ? `/grammar/${slugParts.slice(0, i + 1).join("/")}` : undefined,
}));
if (breadcrumb[0]) breadcrumb[0].href = "/grammar/pronouns";
---

<Base
  title={title}
  breadcrumb={[{ label: "Grammar", href: "/grammar" }, ...breadcrumb.filter(b => b.label !== "Grammar")]}
>
  <article>
    <div class="hgroup">
      <h1>{title}</h1>
      {oneLineRule && <p class="hgroup-rule">{oneLineRule}</p>}
    </div>

    <Content />

    <a href="/grammar/pronouns" class="back-link">← Back to Grammar</a>
  </article>
</Base>
