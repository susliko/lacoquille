---
import Base from "../../../layouts/Base.astro";
import NegationDiagram from "../../../components/NegationDiagram";

const negationParticles = [
  {
    id: "pas",
    label: "pas",
    meaning: "not",
    example: "ne...pas",
    href: "/grammar/negation/basic",
  },
  {
    id: "plus",
    label: "plus",
    meaning: "no longer",
    example: "ne...plus",
    href: "/grammar/negation/basic",
  },
  {
    id: "jamais",
    label: "jamais",
    meaning: "never",
    example: "ne...jamais",
    href: "/grammar/negation/basic",
  },
  {
    id: "rien",
    label: "rien",
    meaning: "nothing",
    example: "ne...rien",
    href: "/grammar/negation/basic",
  },
  {
    id: "personne",
    label: "personne",
    meaning: "nobody",
    example: "ne...personne",
    href: "/grammar/negation/basic",
  },
  {
    id: "aucun",
    label: "aucun(e)",
    meaning: "not any",
    example: "ne...aucun(e)",
    href: "/grammar/negation/basic",
  },
];
---

<Base
  title="Negation"
  breadcrumb={[{ label: "Grammar", href: "/grammar" }, { label: "Negation" }]}
>
  <article>
    <div class="hgroup">
      <h1>Negation</h1>
      <p class="hgroup-rule">French wraps most negatives around the verb in a ne...X pattern.</p>
    </div>

    <NegationDiagram client:only="solid-js" particles={negationParticles} />

    <section>
      <h2>How it works</h2>
      <p>
        French negation uses a two-part structure that wraps around the verb.
        The first part <strong>ne</strong> precedes the verb, and a second particle
        (pas, plus, jamais, rien, personne, aucun) follows it.
      </p>
      <p>
        Together they form a "bracket" around the verb:
      </p>
      <p><em>Je <strong>ne</strong> comprends <strong>pas</strong>.</em> — I don't understand.</p>
    </section>

    <section>
      <h2>Key patterns</h2>
      <table>
        <thead>
          <tr>
            <th>Pattern</th>
            <th>Usage</th>
            <th>Example</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="/grammar/negation/basic">ne...pas</a></td>
            <td>Basic denial</td>
            <td><em>Je ne sais pas.</em> — I don't know.</td>
          </tr>
          <tr>
            <td>ne...plus</td>
            <td>No longer</td>
            <td><em>Elle ne travaille plus ici.</em> — She no longer works here.</td>
          </tr>
          <tr>
            <td>ne...jamais</td>
            <td>Never</td>
            <td><em>Je ne mens jamais.</em> — I never lie.</td>
          </tr>
          <tr>
            <td>ne...rien</td>
            <td>Nothing</td>
            <td><em>Je ne vois rien.</em> — I see nothing.</td>
          </tr>
          <tr>
            <td>ne...personne</td>
            <td>Nobody</td>
            <td><em>Personne ne sait.</em> — Nobody knows.</td>
          </tr>
          <tr>
            <td>ne...aucun(e)</td>
            <td>Not any</td>
            <td><em>Je n'ai aucune idée.</em> — I have no idea.</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Ne expletif</h2>
      <p>
        In formal French, <strong>ne</strong> appears even when there's no real negation,
        especially after verbs of fearing or doubting. This <em>ne</em> adds no negative meaning —
        it's purely grammatical.
      </p>
      <p>
        <em>Je crains qu'il <strong>ne</strong> soit en retard.</em> — I fear he may be late.
      </p>
    </section>

    <a href="/grammar" class="back-link">← Back to Grammar</a>
  </article>
</Base>
