---
import Base from "../layouts/Base.astro";
import HomepageTabs from "../components/HomepageTabs";
---

<Base title="La Coquille" hideNav={true}>
  <HomepageTabs client:only="solid-js" />
</Base>

<style>
  /* ── Tab bar ──────────────────────────────────────────────── */
  .homepage-tabs-root {
    height: calc(100dvh - 64px);
    display: flex;
    flex-direction: column;
  }

  .homepage-tab-bar {
    display: flex;
    gap: 0;
    padding: 0.75rem 1rem 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }

  .homepage-tab-btn {
    all: unset;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-2);
    padding: 0.45rem 1.25rem;
    border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    cursor: pointer;
    transition: color var(--transition), background var(--transition);
    border: 1px solid transparent;
    border-bottom: none;
    position: relative;
  }

  .homepage-tab-btn:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  .homepage-tab-btn.active {
    color: var(--coral);
    background: var(--bg);
    border-color: var(--border-subtle);
  }

  .homepage-tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--bg);
  }

  /* ── Tab panels ───────────────────────────────────────────── */
  .homepage-tab-panel {
    flex: 1;
    overflow: hidden;
  }

  /* ── Practice grid (3×3, like poly-grid) ─────────────────── */
  .practice-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 0;
    height: calc(100dvh - 64px);
    width: 100%;
    max-width: 100dvw;
    overflow: hidden;
  }
</style>