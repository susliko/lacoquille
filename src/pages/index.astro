---
import Base from "../layouts/Base.astro";

const referenceGroups = [
  {
    name: "Verbs",
    href: "/reference/verbs",
    desc: "Every French verb tense and mood — their relations, formations, and when to use each one.",
    subtopics: [],
  },
  {
    name: "Grammar",
    href: "/reference/grammar",
    desc: "The building blocks: pronouns, articles, adjectives, negation, and more.",
    subtopics: [
      { name: "Pronoms", href: "/reference/grammar/pronouns" },
      { name: "Articles", href: "/reference/grammar/articles" },
      { name: "Adjectifs", href: "/reference/grammar/adjectives" },
      { name: "Adverbes", href: "/reference/grammar/adverbs" },
      { name: "Prépositions", href: "/reference/grammar/prepositions" },
      { name: "Négation", href: "/reference/grammar/negation" },
      { name: "Interrogation", href: "/reference/grammar/interrogation" },
      { name: "Syntaxe", href: "/reference/grammar/syntax" },
      { name: "Verbes réfléchis", href: "/reference/grammar/reflexive-verbs" },
    ],
  },
  },
];
---

<Base title="La Coquille">
  <div class="home-hero">
    <div class="home-hero-bg" aria-hidden="true">GRAMMAIRE</div>
    <div class="home-hero-content">
      <p class="home-eyebrow">L'atlas de la langue française</p>
      <h1 class="home-title">French Grammar<br/>Reference</h1>
      <p class="home-subtitle">
        An interactive reference for every aspect of French grammar —
        structured, visual, and built to make the hard parts click.
      </p>
    </div>
  </div>

  <div class="home-sections">
    <a href="/practice" class="home-section-card">
      <div class="section-header">
        <span class="section-label">Practice</span>
        <span class="section-arrow">→</span>
      </div>
      <h2 class="section-title">Article du jour</h2>
      <p class="section-desc">A daily Maupassant short story with translation and vocab.</p>
    </a>

    <div class="home-reference">
      <div class="reference-header">
        <span class="section-label">Reference</span>
      </div>
      <div class="reference-groups">
        {referenceGroups.map(group => (
          <div class="reference-group">
            <a href={group.href} class="group-title">
              <span>{group.name}</span>
              <span class="group-arrow">→</span>
            </a>
            <p class="group-desc">{group.desc}</p>
            {group.subtopics.length > 0 && (
              <div class="subtopics">
                {group.subtopics.map(sub => (
                  <a href={sub.href} class="subtopic">{sub.name}</a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</Base>

<style>
  .home-sections {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 2rem;
  }

  .home-section-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    transition: border-color var(--transition), background var(--transition);
  }
  .home-section-card:hover {
    border-color: var(--gold);
    background: var(--surface-2);
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .section-label {
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .section-arrow {
    font-size: 1rem;
    color: var(--gold);
    opacity: 0;
    transition: opacity var(--transition), transform var(--transition);
  }
  .home-section-card:hover .section-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--text);
    margin: 0;
  }

  .section-desc {
    font-size: 0.85rem;
    color: var(--text-2);
    margin: 0;
  }

  .home-reference {
    background: var(--surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .reference-header {
    padding: 0.75rem 1.25rem;
    background: var(--surface-2);
    border-bottom: 1px solid var(--border-subtle);
  }

  .reference-groups {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border-subtle);
  }
  @media (max-width: 640px) {
    .reference-groups { grid-template-columns: 1fr; }
  }

  .reference-group {
    padding: 1.25rem;
    background: var(--surface);
  }

  .group-title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 0.35rem;
    transition: color var(--transition);
  }
  .group-title:hover { color: var(--gold); }

  .group-arrow {
    font-size: 0.9rem;
    color: var(--gold);
    opacity: 0;
    transition: opacity var(--transition);
  }
  .group-title:hover .group-arrow { opacity: 1; }

  .group-desc {
    font-size: 0.8rem;
    color: var(--text-2);
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  .subtopics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .subtopic {
    font-size: 0.75rem;
    padding: 0.25rem 0.6rem;
    background: var(--surface-2);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--text-2);
    transition: border-color var(--transition), color var(--transition);
  }
  .subtopic:hover {
    border-color: var(--gold);
    color: var(--gold);
  }
</style>
