---
import Base from "../layouts/Base.astro";
import HomepageTabs from "../components/HomepageTabs";
---

<Base title="La Coquille" hideNav={true}>
  <HomepageTabs client:only="solid-js" />
</Base>

<style>
  /* ── Tab bar ──────────────────────────────────────────────── */
  .homepage-tabs-root {
    height: calc(100dvh - 64px);
    display: flex;
    flex-direction: column;
  }

  .homepage-tab-bar {
    display: flex;
    gap: 8px;
    padding: 20px 24px 12px;
    background: var(--bg);
    flex-shrink: 0;
  }

  .homepage-tab-btn {
    flex: 1;
    max-width: 160px;
    font-family: 'DM Serif Display', serif !important;
    font-size: 15px;
    text-align: center;
    padding: 7px 0 9px;
    background: transparent;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    letter-spacing: 0.01em;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .homepage-tab-btn.active {
    color: var(--text);
    font-style: normal;
    border: 2px solid var(--text);
    background: var(--bg);
  }

  .homepage-tab-btn.inactive {
    color: var(--text-muted);
    font-style: italic;
    border: 1.5px dashed var(--border-subtle);
  }

  .homepage-tab-btn.inactive:hover {
    color: var(--text-2);
    border-color: var(--border);
  }

  /* ── Tab panels ───────────────────────────────────────────── */
  .homepage-tab-panel {
    flex: 1;
    overflow: hidden;
  }

  /* ── Practice grid (3×3, like poly-grid) ─────────────────── */
  .practice-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 0;
    height: calc(100dvh - 64px);
    width: 100%;
    max-width: 100dvw;
    overflow: hidden;
  }
</style>