---
import Base from "../../../../layouts/Base.astro";

const articleNodes = [
  {
    id: "a-de",
    label: "à and de",
    forms: ["au", "aux", "du", "des"],
    description: "Contractions with articles",
    href: "/grammar/prepositions/a-de",
  },
  {
    id: "verb-combinations",
    label: "Verb Combinations",
    forms: ["à", "de", "en", "sur"],
    description: "Prepositions after verbs",
    href: "/grammar/prepositions/verb-combinations",
  },
];
---

<Base
  title="Prepositions"
  breadcrumb={[{ label: "Grammar", href: "/reference/grammar" }, { label: "Prepositions" }]}
>
  <article>
    <div class="hgroup">
      <h1>Prepositions</h1>
      <p class="hgroup-rule">Words that connect nouns, pronouns, or verbs to other elements in a sentence.</p>
    </div>

    <section>
      <h2>The core prepositions</h2>
      <p>
        French has two dominant prepositions: <strong>à</strong> (to, at) and <strong>de</strong> (of, from).
        These combine with articles to form contractions that you'll encounter constantly.
      </p>

      <table>
        <thead>
          <tr>
            <th>Contraction</th>
            <th>Full form</th>
            <th>Example</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><a href="/reference/grammar/prepositions/a-de"><em>au</em></a></td>
            <td>à + le</td>
            <td><em>au marché</em> — to the market</td>
          </tr>
          <tr>
            <td><a href="/reference/grammar/prepositions/a-de"><em>aux</em></a></td>
            <td>à + les</td>
            <td><em>aux enfants</em> — to the children</td>
          </tr>
          <tr>
            <td><a href="/reference/grammar/prepositions/a-de"><em>du</em></a></td>
            <td>de + le</td>
            <td><em>du travail</em> — from the work</td>
          </tr>
          <tr>
            <td><a href="/reference/grammar/prepositions/a-de"><em>des</em></a></td>
            <td>de + les</td>
            <td><em>des amis</em> — from the friends</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section>
      <h2>Verb + preposition patterns</h2>
      <p>
        Many French verbs require specific prepositions before their objects.
        These don't always match English, so they need memorization.
      </p>
      <p>
        <a href="/reference/grammar/prepositions/verb-combinations">View common verb combinations →</a>
      </p>
    </section>

    <a href="/reference/grammar" class="back-link">← Grammar</a>
  </article>
</Base>
