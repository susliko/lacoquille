---
import Base from "../../../../layouts/Base.astro";

const questionMethods = [
  {
    id: "intonation",
    label: "Intonation",
    pattern: "Tu viens ?",
    description: "Voice rises at the end",
    formality: "Informal",
    href: "/reference/grammar/interrogation/three-methods",
  },
  {
    id: "est-ce-que",
    label: "Est-ce que",
    pattern: "Est-ce que tu viens ?",
    description: "Insert est-ce que before statement",
    formality: "Standard",
    href: "/reference/grammar/interrogation/three-methods",
  },
  {
    id: "inversion",
    label: "Inversion",
    pattern: "Viens-tu ?",
    description: "Swap subject and verb",
    formality: "Formal",
    href: "/reference/grammar/interrogation/three-methods",
  },
];

const questionWords = [
  { word: "Qui", meaning: "Who" },
  { word: "Que", meaning: "What" },
  { word: "Quoi", meaning: "What (informal)" },
  { word: "Où", meaning: "Where" },
  { word: "Quand", meaning: "When" },
  { word: "Comment", meaning: "How" },
  { word: "Pourquoi", meaning: "Why" },
  { word: "Combien", meaning: "How many/much" },
];
---

<Base
  title="Interrogation"
  breadcrumb={[{ label: "Grammar", href: "/reference/grammar" }, { label: "Questions" }]}
>
  <article>
    <div class="hgroup">
      <h1>Asking Questions</h1>
      <p class="hgroup-rule">French has three ways to turn a statement into a question.</p>
    </div>

    <section>
      <h2>Three methods</h2>
      <div class="method-cards">
        {questionMethods.map(method => (
          <a href={method.href} class="method-card">
            <span class="method-label">{method.label}</span>
            <span class="method-pattern">{method.pattern}</span>
            <span class="method-desc">{method.description}</span>
            <span class="method-formality">{method.formalityity}</span>
          </a>
        ))}
      </div>
      <p><a href="/reference/grammar/interrogation/three-methods">Learn all three methods →</a></p>
    </section>

    <section>
      <h2>Question words</h2>
      <p>Use these to ask for specific information:</p>
      <div class="words-grid">
        {questionWords.map(w => (
          <div class="word-item">
            <em>{w.word}</em>
            <span>{w.meaning}</span>
          </div>
        ))}
      </div>
      <p><a href="/reference/grammar/interrogation/question-words">Question words details →</a></p>
    </section>

    <a href="/reference/grammar" class="back-link">← Grammar</a>
  </article>
</Base>

<style>
  .method-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .method-card {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 0.5rem;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .method-card:hover {
    border-color: var(--accent);
  }

  .method-label {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .method-pattern {
    font-size: 1.25rem;
    font-family: var(--font-display);
  }

  .method-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .method-formality {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    background: var(--bg-elevated);
    border-radius: 1rem;
    width: fit-content;
    margin-top: auto;
  }

  .words-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 0.75rem;
    margin: 1rem 0;
  }

  .word-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: 0.75rem;
    background: var(--bg-elevated);
    border-radius: 0.375rem;
  }

  .word-item em {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .word-item span {
    font-size: 0.875rem;
    color: var(--text-muted);
  }
</style>