---
import Base from "../../../layouts/Base.astro";

const topics = [
  { name: "Pronoms",          desc: "Subject, object, reflexive, relative, demonstrative, possessive & more.", href: "/reference/grammar/pronouns" },
  { name: "Articles",          desc: "Definite, indefinite, partitive — when to use le, un, du.",              href: "/reference/grammar/articles" },
  { name: "Adjectifs",         desc: "Agreement, placement, comparison, formation.",                           href: "/reference/grammar/adjectifs" },
  { name: "Adverbes",          desc: "Formation, placement, degree, commonly used adverbs.",                  href: "/reference/grammar/adverbs" },
  { name: "Prépositions",      desc: "à, de & common verb combinations.",                                      href: "/reference/grammar/prepositions" },
  { name: "Négation",          desc: "ne…pas, ne…plus, ne…jamais & more.",                                    href: "/reference/grammar/negation" },
  { name: "Interrogation",     desc: "Inversion, est-ce que, intonation — three ways to ask.",                href: "/reference/grammar/interrogation" },
  { name: "Syntaxe",           desc: "Word order, sentence structure, clause chaining.",                       href: "/reference/grammar/syntax" },
  { name: "Verbes réfléchis",  desc: "Reflexive verbs: se réveiller, s'habiller, se casser.",                  href: "/reference/grammar/reflexive-verbs" },
];
---

<Base title="Grammar — La Coquille" section="reference/grammar">
  <div class="home-hero">
    <div class="home-hero-bg" aria-hidden="true">GRAMMAIRE</div>
    <div class="home-hero-content">
      <p class="home-eyebrow">Grammaire française</p>
      <h1>Grammar</h1>
      <p class="home-subtitle">
        Every topic in French grammar — from pronouns to word order,
        structured with visual diagrams and clear rules.
      </p>
    </div>
  </div>

  <div class="topic-grid">
    {topics.map(topic => (
      <a href={topic.href} class="topic-card available">
        <span class="topic-badge">available</span>
        <span class="topic-name">{topic.name}</span>
        <span class="topic-desc">{topic.desc}</span>
      </a>
    ))}
  </div>
</Base>
