{
  "name": "minor-mass",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:all": "concurrently \"cd lacq && cargo run\" \"astro dev\"",
    "dev:prod": "npm run build && concurrently \"cd lacq && cargo run\" \"astro preview\"",
    "build": "astro build && node scripts/check-links.mjs",
    "check:links": "astro build && node scripts/check-links.mjs",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/solid-js": "^6.0.1",
    "astro": "^6.1.7",
    "express": "^5.2.1",
    "playwright": "^1.59.1",
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
